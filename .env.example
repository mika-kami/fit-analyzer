# Copy to .env and fill in your Supabase project values
# Found in: supabase.com → your project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key...

# Strava OAuth — create app at https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to your domain (e.g. localhost or your-app.vercel.app)
VITE_STRAVA_CLIENT_ID=your_strava_client_id
# Server-side only (used by /api/strava/token, NOT exposed to browser):
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
