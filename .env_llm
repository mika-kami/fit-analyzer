# LLM configuration for AI coach chat
# This file is tracked in git — no secrets here.
# API key stays in .env (VITE_OPENAI_API_KEY)

VITE_LLM_URL=https://api.openai.com/v1/chat/completions
VITE_LLM_MODEL=gpt-4o-mini
VITE_LLM_MAX_TOKENS=2000

VITE_PLAN_LLM_MODEL=gpt-5.4-mini
VITE_PLAN_MAX_TOKENS=16000

VITE_COACH_LLM_MODEL=gpt-5.4-mini

